static string ObtenerTextoClasif(int clasif)
{
    if (clasif == 1) return "Todo público";
    if (clasif == 2) return "+13";
    return "+18";
}

static string ObtenerTextoProduccion(int prod)
{
    if (prod == 1) return "Baja";
    if (prod == 2) return "Media";
    return "Alta";
}


